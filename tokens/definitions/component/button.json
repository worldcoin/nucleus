{
  "component": {
    "button": {
      "description": "Button style tokens (UI Kit 5.0). Variant colors reference semantic tokens; sizes carry geometry + the subtitle font for the label. Pressed is a 1px inset applied by the client, not a separate color.",
      "variants": {
        "primary": {
          "background": "{semantic.color.action.primary}",
          "content": "{semantic.color.action.primaryContent}"
        },
        "secondary": {
          "background": "{semantic.color.action.secondary}",
          "content": "{semantic.color.action.secondaryContent}"
        },
        "tertiary": {
          "background": "{semantic.color.action.tertiary}",
          "content": "{semantic.color.action.tertiaryContent}",
          "border": "{semantic.color.border.default}"
        },
        "ghost": {
          "background": "{semantic.color.action.ghost}",
          "content": "{semantic.color.action.ghostContent}"
        },
        "inverse": {
          "background": "{semantic.color.surface.elevated}",
          "content": "{semantic.color.text.primary}"
        },
        "disabled": {
          "background": "{semantic.color.action.disabled}",
          "content": "{semantic.color.action.disabledContent}"
        }
      },
      "sizes": {
        "48": {
          "height": 48,
          "cornerRadius": 24,
          "paddingHorizontal": 24,
          "paddingVertical": 12,
          "font": "s1"
        },
        "40": {
          "height": 40,
          "cornerRadius": 20,
          "paddingHorizontal": 20,
          "paddingVertical": 10,
          "font": "s2"
        },
        "32": {
          "height": 32,
          "cornerRadius": 16,
          "paddingHorizontal": 16,
          "paddingVertical": 6,
          "font": "s3"
        }
      },
      "pressedInset": 1
    }
  }
}
