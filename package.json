    "format:check": "prettier --check \"**/*.json\"",
    "clean": "rm -rf build"
  },
  "dependencies": {
    "handlebars": "^4.7.9"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "oxlint": "^1.51.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
