{
  "name": "@worldcoin/nucleus-monorepo",
  "version": "0.2.1",
  "private": true,
  "description": "Design tokens for the World ecosystem (source repo; the published package is built into build/web)",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "build": "npm run clean && tsx tokens/build/index.ts",
    "typecheck": "tsc --noEmit",
